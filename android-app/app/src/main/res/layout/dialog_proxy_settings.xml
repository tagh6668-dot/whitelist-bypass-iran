<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/proxy_port_label"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/proxyPortInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="1080" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/proxy_auth_mode_label"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/authModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/authModeAuto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/proxy_auth_auto" />

        <RadioButton
            android:id="@+id/authModeManual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/proxy_auth_manual" />

    </RadioGroup>

    <LinearLayout
        android:id="@+id/manualAuthContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/proxyUserInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/proxy_username_hint"
            android:inputType="text" />

        <EditText
            android:id="@+id/proxyPassInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/proxy_password_hint"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/copyProxyButton"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="@string/proxy_copy" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="?android:attr/listDivider" />

    <CheckBox
        android:id="@+id/proxyOnlyCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/proxy_only_label" />

</LinearLayout>
